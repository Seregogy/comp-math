// Функция для извлечения слов из текста
std::vector<std::string> extract_words(const std::string& filename) {
    std::ifstream file(filename);
    std::vector<std::string> words;
    std::string word;
    
    if (!file.is_open()) {
        std::cerr << "Ошибка: не удалось открыть файл " << filename << std::endl;
        return words;
    }
    
    char ch;
    while (file.get(ch)) {
        if (std::isalpha(static_cast<unsigned char>(ch))) {
            word.push_back(std::tolower(static_cast<unsigned char>(ch)));
        } else if (!word.empty()) {
            words.push_back(word);
            word.clear();
        }
    }
    
    if (!word.empty()) {
        words.push_back(word);
    }
    
    file.close();
    return words;
}

// Поиск N самых длинных слов через PriorityQueueHeap (бинарная куча)
std::vector<std::string> find_top_n_words_heap(const std::vector<std::string>& words, size_t n) {
    if (n == 0) return {};
    
    // Компаратор для min-heap (храним наименьшие вверху)
    auto cmp = [](const std::string& a, const std::string& b) {
        return a.length() > b.length(); // > для min-heap
    };
    
    PriorityQueueHeap<std::string, std::vector<std::string>, decltype(cmp)> pq(cmp);
    
    for (const auto& word : words) {
        pq.push(word);
        if (pq.size() > n) {
            pq.pop();
        }
    }
    
    // Извлекаем результаты и сортируем по убыванию длины
    std::vector<std::string> result;
    while (!pq.empty()) {
        result.push_back(pq.top());
        pq.pop();
    }
    
    // Сортируем по длине (от длинных к коротким)
    std::sort(result.begin(), result.end(), 
              [](const std::string& a, const std::string& b) {
                  return a.length() > b.length();
              });
    
    return result;
}

// Поиск N самых длинных слов через PriorityQueueVector (отсортированный массив)
std::vector<std::string> find_top_n_words_vector(const std::vector<std::string>& words, size_t n) {
    if (n == 0) return {};
    
    auto cmp = [](const std::string& a, const std::string& b) {
        return a.length() < b.length();
    };
    
    PriorityQueueVector<std::string, decltype(cmp)> pq(cmp);
    
    for (const auto& word : words) {
        pq.push(word);
        if (pq.size() > n) {
            pq.pop();
        }
    }
    
    std::vector<std::string> result;
    while (!pq.empty()) {
        result.push_back(pq.top());
        pq.pop();
    }
    
    std::sort(result.begin(), result.end(), 
              [](const std::string& a, const std::string& b) {
                  return a.length() > b.length();
              });
    
    return result;
}

