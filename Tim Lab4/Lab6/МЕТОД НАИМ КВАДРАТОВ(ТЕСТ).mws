{MPLTEXT 1 0 11 "end do;\n\n  " }{MPLTEXT 1 0 43 "A:=(n*SumXY-SumX*Sum
Y)/(n*SumXX-SumX^2);\n  " }{MPLTEXT 1 0 28 "B:=(SumY - A * SumX) / n;
\n  " }{MPLTEXT 1 0 13 "return A, B;\n" }{MPLTEXT 1 0 9 "end proc;" }}
