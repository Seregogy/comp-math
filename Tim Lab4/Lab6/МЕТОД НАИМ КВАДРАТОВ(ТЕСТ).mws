 SumXY:=0;\n  " }{MPLTEXT 1 0 21 "for i from 1 to n do\n" }{MPLTEXT 1 
0 28 "    SumX:=evalf(SumX+X[i]);\n" }{MPLTEXT 1 0 29 "    SumY:=evalf
(SumY+Y[i]); \n" }{MPLTEXT 1 0 37 "    SumXX:=evalf(SumXX+X[i]*X[i]); \+
